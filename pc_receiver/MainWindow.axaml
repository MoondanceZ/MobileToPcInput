<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:pc_receiver"
        x:Class="pc_receiver.MainWindow"
        Width="860"
        Height="620"
        MinWidth="860"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        Title="MobileToPcInput">
  <Window.Resources>
    <DataTemplate x:Key="SelectedModelTemplate"
                  x:DataType="local:AsrModelOption">
      <TextBlock Text="{Binding DisplayName}"
                 FontSize="13"
                 Foreground="#1F334D"
                 TextTrimming="CharacterEllipsis"
                 VerticalAlignment="Center" />
    </DataTemplate>

    <DataTemplate x:Key="ModelDropDownItemTemplate"
                  x:DataType="local:AsrModelOption">
      <Border Width="{Binding #DeviceBox.Bounds.Width}"
              MinHeight="54"
              Padding="12,8">
        <Grid RowDefinitions="Auto,Auto">
          <TextBlock Text="{Binding DisplayName}"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="#1C2739"
                     TextTrimming="CharacterEllipsis" />
          <TextBlock Grid.Row="1"
                     Margin="0,3,0,0"
                     Text="{Binding Description}"
                     FontSize="12"
                     Foreground="#718096"
                     TextWrapping="Wrap"
                     MaxLines="2" />
        </Grid>
      </Border>
    </DataTemplate>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="ComboBox#DeviceBox">
      <Setter Property="Padding" Value="12,0,10,0" />
      <Setter Property="Foreground" Value="#1F334D" />
      <Setter Property="BorderBrush" Value="#D6E0EC" />
      <Setter Property="Background" Value="White" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="MaxDropDownHeight" Value="220" />
    </Style>
    <Style Selector="ComboBox#DeviceBox:pointerover">
      <Setter Property="BorderBrush" Value="#AFC3DD" />
      <Setter Property="Background" Value="#FBFDFF" />
    </Style>
    <Style Selector="ComboBox#DeviceBox:focus">
      <Setter Property="BorderBrush" Value="#1769E0" />
    </Style>
    <Style Selector="ComboBox#DeviceBox /template/ Popup#PART_Popup">
      <Setter Property="Width" Value="{Binding #DeviceBox.Bounds.Width}" />
    </Style>
    <Style Selector="ComboBox#DeviceBox /template/ Popup#PART_Popup Border">
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="BorderBrush" Value="#D8E1EC" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="#FAFCFF" />
      <Setter Property="BoxShadow" Value="0 10 22 0 #1A273B30" />
    </Style>
    <Style Selector="ComboBoxItem">
      <Setter Property="IsEnabled" Value="{ReflectionBinding CanSelectInPicker}" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="4,3" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ComboBoxItem:disabled">
      <Setter Property="Opacity" Value="0.48" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ComboBoxItem:pointerover">
      <Setter Property="Background" Value="#EEF6FF" />
    </Style>
    <Style Selector="ComboBoxItem:selected">
      <Setter Property="Background" Value="#E7F0FF" />
    </Style>
  </Window.Styles>

  <Border x:Name="Surface"
          CornerRadius="18"
          ClipToBounds="True"
          BorderBrush="#D8E1EC"
          BorderThickness="1"
          BoxShadow="0 18 34 0 #2D17263B">
    <Border.Background>
      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#F8FBFF" Offset="0" />
        <GradientStop Color="#E9F0F9" Offset="1" />
      </LinearGradientBrush>
    </Border.Background>

    <Grid RowDefinitions="82,*">
      <Grid x:Name="TitleBar"
            Grid.Row="0"
            ColumnDefinitions="52,*,168"
            Margin="24,18,18,12"
            Background="Transparent">
        <Image x:Name="LogoImage"
               Width="42"
               Height="42"
               Stretch="Uniform"
               VerticalAlignment="Center" />

        <StackPanel Grid.Column="1"
                    Spacing="1"
                    VerticalAlignment="Center">
          <TextBlock Text="MobileToPcInput"
                     FontSize="22"
                     FontWeight="SemiBold"
                     Foreground="#1C2739" />
          <TextBlock Text="手机麦克风接收器 · 本地语音识别"
                     FontSize="12"
                     Foreground="#718096" />
        </StackPanel>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
          <Button Width="42"
                  Height="34"
                  MinHeight="34"
                  Padding="0"
                  Click="MinimizeButton_Click"
                  Content="─"
                  FontSize="18"
                  FontWeight="Normal"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"
                  Background="#F8FAFC"
                  Foreground="#1F334D"
                  BorderBrush="#D6E0EC"
                  BorderThickness="1"
                  CornerRadius="10" />
          <Button Width="42"
                  Height="34"
                  MinHeight="34"
                  Padding="0"
                  Click="CloseButton_Click"
                  Content="×"
                  FontSize="18"
                  FontWeight="Normal"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"
                  Background="#F8FAFC"
                  Foreground="#1F334D"
                  BorderBrush="#D6E0EC"
                  BorderThickness="1"
                  CornerRadius="10" />
        </StackPanel>
      </Grid>

      <Grid Grid.Row="1"
            Margin="24,0,24,24"
            ColumnDefinitions="1.04*,18,0.96*"
            RowDefinitions="Auto,*,Auto">
        <Border Grid.Column="0"
                Grid.RowSpan="2"
                Padding="18"
                CornerRadius="18"
                Background="White"
                BorderBrush="#DDE6F1"
                BorderThickness="1"
                BoxShadow="0 8 18 0 #1217263B">
          <StackPanel Spacing="14">
            <StackPanel Spacing="4">
              <TextBlock Text="电脑连接信息"
                         FontSize="18"
                         FontWeight="SemiBold"
                         Foreground="#1C2739" />
              <TextBlock Text="手机端填入这里显示的 IP 和端口"
                         FontSize="13"
                         Foreground="#718096" />
            </StackPanel>

            <Border CornerRadius="14"
                    Padding="14,12"
                    Background="#F4F7FB"
                    BorderBrush="#DDE6F1"
                    BorderThickness="1">
              <Grid ColumnDefinitions="*,16,112">
                <StackPanel Spacing="8"
                            VerticalAlignment="Center">
                  <TextBlock Text="局域网地址"
                             FontSize="12"
                             FontWeight="SemiBold"
                             Foreground="#536174" />
                  <TextBlock x:Name="IpText"
                             FontSize="24"
                             FontWeight="SemiBold"
                             Foreground="#1769E0"
                             TextWrapping="NoWrap" />
                  <TextBlock Text="手机扫码或手动输入这个地址"
                             FontSize="12"
                             Foreground="#718096" />
                </StackPanel>

                <Border Grid.Column="2"
                        Width="104"
                        Height="104"
                        CornerRadius="12"
                        Padding="8"
                        Background="White"
                        BorderBrush="#DDE6F1"
                        BorderThickness="1">
                  <Image x:Name="QrImage"
                         Stretch="Uniform" />
                </Border>
              </Grid>
            </Border>

            <Grid ColumnDefinitions="108,*" RowDefinitions="Auto,Auto" RowSpacing="12">
              <TextBlock Grid.Row="0"
                         Grid.Column="0"
                         VerticalAlignment="Center"
                         Text="监听端口"
                         Foreground="#536174"
                         FontWeight="SemiBold" />
              <TextBox x:Name="PortBox"
                       Grid.Row="0"
                      Grid.Column="1"
                      Height="38"
                      Text="8765"
                      PlaceholderText="8765"
                      CornerRadius="9"
                      BorderBrush="#D6E0EC"
                      Background="White"
                      VerticalContentAlignment="Center"
                      Padding="10,0" />

              <TextBlock Grid.Row="1"
                         Grid.Column="0"
                         VerticalAlignment="Center"
                         Text="语音模型"
                         Foreground="#536174"
                         FontWeight="SemiBold" />
              <ComboBox x:Name="DeviceBox"
                        Grid.Row="1"
                        Grid.Column="1"
                        MinHeight="38"
                        CornerRadius="9"
                        BorderBrush="#D6E0EC"
                        Background="White"
                        ItemTemplate="{StaticResource ModelDropDownItemTemplate}"
                        SelectionBoxItemTemplate="{StaticResource SelectedModelTemplate}" />
            </Grid>

            <Grid ColumnDefinitions="Auto,12,Auto,*,Auto">
              <Button x:Name="StartButton"
                      Grid.Column="0"
                      MinHeight="38"
                      Padding="14,8"
                      Click="StartButton_Click"
                      Content="开始监听"
                      FontSize="14"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center"
                      Background="#1769E0"
                      Foreground="White"
                      BorderBrush="#1769E0"
                      BorderThickness="1"
                      CornerRadius="10"
                      FontWeight="SemiBold" />
              <Button x:Name="StopButton"
                      Grid.Column="2"
                      MinHeight="38"
                      Padding="14,8"
                      IsEnabled="False"
                      Click="StopButton_Click"
                      Content="停止监听"
                      FontSize="14"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center"
                      Background="#F8FAFC"
                      Foreground="#1F334D"
                      BorderBrush="#D6E0EC"
                      BorderThickness="1"
                      CornerRadius="10"
                      FontWeight="SemiBold" />
              <Button x:Name="ManageModelButton"
                      Grid.Column="4"
                      MinHeight="38"
                      Padding="14,8"
                      Click="ManageModelButton_Click"
                      Content="模型管理"
                      FontSize="14"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center"
                      Background="#F8FAFC"
                      Foreground="#1F334D"
                      BorderBrush="#D6E0EC"
                      BorderThickness="1"
                      CornerRadius="10"
                      FontWeight="SemiBold" />
            </Grid>
          </StackPanel>
        </Border>

        <StackPanel Grid.Column="2"
                    Grid.Row="0"
                    Spacing="12">
          <Border x:Name="StatusPill"
                  CornerRadius="14"
                  Padding="16,10"
                  Background="#FFF1F0">
            <TextBlock x:Name="StatusText"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Text="● 未监听"
                       Foreground="#C13830" />
          </Border>

          <Border Padding="18"
                  CornerRadius="18"
                  Background="White"
                  BorderBrush="#DDE6F1"
                  BorderThickness="1"
                  BoxShadow="0 8 18 0 #1217263B">
            <StackPanel Spacing="14">
              <StackPanel Spacing="4">
                <TextBlock Text="实时状态"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#1C2739" />
                <TextBlock x:Name="ClientText"
                           Text="手机未连接"
                           FontSize="13"
                           Foreground="#718096" />
              </StackPanel>

              <Grid ColumnDefinitions="72,*">
                <TextBlock Text="音量"
                           FontSize="12"
                           Foreground="#718096"
                           VerticalAlignment="Center" />
                <ProgressBar x:Name="LevelBar"
                             Grid.Column="1"
                             Height="12"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             CornerRadius="8"
                             Foreground="#1769E0"
                             Background="#DDE6F1" />
              </Grid>

              <Border CornerRadius="12"
                      Padding="12"
                      Background="#F7FAFE"
                      BorderBrush="#E1E8F0"
                      BorderThickness="1">
                <TextBlock x:Name="HintText"
                           FontSize="13"
                           Foreground="#8A4B00"
                           TextWrapping="Wrap" />
              </Border>
            </StackPanel>
          </Border>
        </StackPanel>

        <Border Grid.Column="2"
                Grid.Row="1"
                Margin="0,12,0,0"
                Padding="18"
                CornerRadius="18"
                Background="#FAFCFF"
                BorderBrush="#D8E1EC"
                BorderThickness="1">
          <StackPanel Spacing="12">
            <TextBlock Text="系统"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#536174" />
            <Border CornerRadius="10"
                    Background="White"
                    BorderBrush="#DDE6F1"
                    BorderThickness="1"
                    Padding="10,8">
              <CheckBox x:Name="StartupBox"
                        VerticalAlignment="Center"
                        Foreground="#1F334D"
                        Content="开机自动启动 MobileToPcInput" />
            </Border>
            <TextBlock Text="关闭窗口会隐藏到托盘，托盘菜单可以显示窗口或退出程序。"
                       FontSize="12"
                       Foreground="#718096"
                       TextWrapping="Wrap" />
            <Button MinHeight="38"
                    Padding="14,8"
                    Click="ClearAudioCacheButton_Click"
                    Content="清理语音缓存"
                    FontSize="14"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="#F8FAFC"
                    Foreground="#1F334D"
                    BorderBrush="#D6E0EC"
                    BorderThickness="1"
                    CornerRadius="10"
                    FontWeight="SemiBold" />
          </StackPanel>
        </Border>

        <Border Grid.Column="0"
                Grid.ColumnSpan="3"
                Grid.Row="2"
                Margin="0,16,0,0"
                CornerRadius="12"
                Background="#F7FAFE"
                BorderBrush="#E1E8F0"
                BorderThickness="1"
                Padding="14,10">
          <TextBlock Text="使用流程：电脑端开始监听；手机连接后按住说话，松开后由本机 Paraformer 识别，并把文本直接输入到当前输入框。"
                     FontSize="13"
                     Foreground="#536174"
                     TextWrapping="Wrap" />
        </Border>
      </Grid>
    </Grid>
  </Border>
</Window>
